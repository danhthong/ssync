<ui:FluentWindow x:Class="SandboxSync.Views.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:vm="clr-namespace:SandboxSync.ViewModels"
                 xmlns:models="clr-namespace:SandboxSync.Models"
                 Title="Sandbox Sync"
                 Width="1280"
                 Height="800"
                 MinWidth="1024"
                 MinHeight="680"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica">
    <ui:FluentWindow.Resources>
        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>
    </ui:FluentWindow.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <!-- LEFT: Master -->
        <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource PanelCard}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Main Window" Style="{StaticResource SectionTitle}" />
                <StackPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
                    <TextBlock Text="Title filter (contains)" Margin="0,0,0,4" Opacity="0.8" />
                    <ui:TextBox Text="{Binding TitleFilter, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="e.g. Dragon Hunters" Margin="0,0,0,8" />
                    <TextBlock Text="Sandbox filter" Margin="0,0,0,4" Opacity="0.8" />
                    <ui:TextBox Text="{Binding SandboxFilter, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="e.g. DefaultBox" Margin="0,0,0,8" />
                    <ui:Button Content="Refresh Windows" Command="{Binding RefreshWindowsCommand}" HorizontalAlignment="Stretch" />
                </StackPanel>

                <ListBox ItemsSource="{Binding Windows}"
                         SelectedItem="{Binding MasterWindow, Mode=TwoWay}"
                         BorderThickness="0"
                         Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:WindowItemViewModel}">
                            <Border CornerRadius="8" Padding="8" Background="#252525">
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding ProcessName}" Opacity="0.75" FontSize="12" />
                                    <TextBlock Text="{Binding HandleText}" Opacity="0.6" FontSize="11" />
                                    <TextBlock Text="{Binding SandboxName}" Opacity="0.6" FontSize="11" />
                                    <ui:Button Content="Set as Main" Margin="0,6,0,0"
                                               Command="{Binding DataContext.SetMasterCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                               CommandParameter="{Binding}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- CENTER: Targets -->
        <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource PanelCard}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Target Windows" Style="{StaticResource SectionTitle}" />
                <TextBlock DockPanel.Dock="Top" Text="Select sandbox instances to mirror clicks into. The main window is excluded automatically." Opacity="0.7" Margin="0,-6,0,10" TextWrapping="Wrap" />

                <ListBox ItemsSource="{Binding Targets}"
                         BorderThickness="0"
                         Background="Transparent"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:WindowItemViewModel}">
                            <Border CornerRadius="8" Padding="10" Margin="0,2" Background="#222222">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0"
                                              IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              VerticalAlignment="Center"
                                              Margin="0,0,10,0" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding DisplayLabel}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock Text="{Binding HandleText}" Opacity="0.65" FontSize="11" Margin="0,0,12,0" />
                                            <TextBlock Text="{Binding SandboxName}" Opacity="0.65" FontSize="11" />
                                        </StackPanel>
                                        <TextBlock Opacity="0.55" FontSize="11">
                                            <Run Text="Client: " />
                                            <Run Text="{Binding Info.ClientWidth, Mode=OneWay}" />
                                            <Run Text="x" />
                                            <Run Text="{Binding Info.ClientHeight, Mode=OneWay}" />
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- RIGHT: Logs -->
        <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource PanelCard}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Event Log" Style="{StaticResource SectionTitle}" />
                <ListBox ItemsSource="{Binding Logs}"
                         BorderThickness="0"
                         Background="Transparent"
                         FontFamily="Cascadia Mono, Consolas, monospace"
                         FontSize="12">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:LogEntry}">
                            <TextBlock Text="{Binding}" TextWrapping="Wrap" Foreground="#D0D0D0" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- BOTTOM: Controls -->
        <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Style="{StaticResource PanelCard}" Margin="6,12,6,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <ui:Button Content="Start Sync" Appearance="Primary" Command="{Binding StartSyncCommand}" Margin="0,0,8,0" />
                    <ui:Button Content="Stop" Command="{Binding StopSyncCommand}" Margin="0,0,8,0" />
                    <ui:Button Content="Pause / Resume" Command="{Binding TogglePauseCommand}" Margin="0,0,8,0" />
                    <ui:Button Content="Settings" Click="OpenSettings_Click" />
                </StackPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="24,0">
                    <Border Style="{StaticResource StatusPill}">
                        <TextBlock Text="{Binding StatusText}" Foreground="#7DFFA4" FontWeight="SemiBold" />
                    </Border>
                    <TextBlock Margin="0,6,0,0" Opacity="0.7" FontSize="12">
                        <Run Text="Hotkeys: Ctrl+Shift+S start | Ctrl+Shift+X stop | Ctrl+Shift+P pause" />
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <ui:TextBox Text="{Binding ProfileName, UpdateSourceTrigger=PropertyChanged}" Width="140" PlaceholderText="Profile name" Margin="0,0,8,0" />
                    <ui:Button Content="Save" Command="{Binding SaveProfileCommand}" Margin="0,0,8,0" />
                    <ui:Button Content="Load" Command="{Binding LoadProfileCommand}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
