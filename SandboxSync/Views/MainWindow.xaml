<ui:FluentWindow x:Class="SandboxSync.Views.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:vm="clr-namespace:SandboxSync.ViewModels"
                 Title="Sandbox Sync"
                 Width="980"
                 Height="700"
                 MinWidth="800"
                 MinHeight="560"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica">
    <ui:FluentWindow.Resources>
        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <ui:TitleBar Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                     Title="Sandbox Sync"
                     ShowMaximize="True"
                     ShowMinimize="True"
                     ShowClose="True"
                     CanMaximize="True" />

        <Grid.Resources>
            <Thickness x:Key="PanelMargin">16,4,16,0</Thickness>
        </Grid.Resources>

        <!-- LEFT: Main window -->
        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource PanelCard}" Margin="16,4,4,4">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Main Window" Style="{StaticResource SectionTitle}" />

                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                    <TextBlock Text="Title filter (contains)" Margin="0,0,0,4" Opacity="0.8" />
                    <ui:TextBox Text="{Binding TitleFilter, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="e.g. Dragon Hunters" Margin="0,0,0,8" />
                    <ui:Button Content="Refresh Windows" Command="{Binding RefreshWindowsCommand}" HorizontalAlignment="Stretch" />
                </StackPanel>

                <ListBox ItemsSource="{Binding Windows}"
                         SelectedItem="{Binding MasterWindow, Mode=TwoWay}"
                         BorderThickness="0"
                         Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:WindowItemViewModel}">
                            <Border CornerRadius="8" Padding="8" Background="#252525">
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding ProcessName}" Opacity="0.7" FontSize="12" />
                                    <TextBlock Text="{Binding HandleText}" Opacity="0.55" FontSize="11" />
                                    <ui:Button Content="Set as Main"
                                               Margin="0,6,0,0"
                                               HorizontalAlignment="Stretch"
                                               Command="{Binding DataContext.SetMasterCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                               CommandParameter="{Binding}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- RIGHT: Targets -->
        <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource PanelCard}" Margin="4,4,16,4">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Target Windows" Style="{StaticResource SectionTitle}" />
                <TextBlock DockPanel.Dock="Top" Text="Tick the windows that should mirror clicks from the main window. The main window is excluded automatically." Opacity="0.7" Margin="0,-6,0,10" TextWrapping="Wrap" />

                <ListBox ItemsSource="{Binding Targets}"
                         BorderThickness="0"
                         Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:WindowItemViewModel}">
                            <Border CornerRadius="8" Padding="10" Margin="0,2" Background="#222222">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0"
                                              IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              VerticalAlignment="Center"
                                              Margin="0,0,10,0" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0" Opacity="0.65">
                                            <TextBlock Text="{Binding ProcessName}" FontSize="11" Margin="0,0,12,0" />
                                            <TextBlock Text="{Binding HandleText}" FontSize="11" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- BOTTOM: Controls -->
        <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource PanelCard}" Margin="16,4,16,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <ui:Button Content="Start Sync" Appearance="Primary" Command="{Binding StartSyncCommand}" Margin="0,0,8,0" />
                    <ui:Button Content="Stop" Command="{Binding StopSyncCommand}" Margin="0,0,8,0" />
                    <ui:Button Content="Pause / Resume" Command="{Binding TogglePauseCommand}" />
                </StackPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="24,0">
                    <Border Style="{StaticResource StatusPill}">
                        <TextBlock Text="{Binding StatusText}" Foreground="#7DFFA4" FontWeight="SemiBold" />
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <ui:TextBox Text="{Binding ProfileName, UpdateSourceTrigger=PropertyChanged}" Width="140" PlaceholderText="Profile name" Margin="0,0,8,0" />
                    <ui:Button Content="Save" Command="{Binding SaveProfileCommand}" Margin="0,0,8,0" />
                    <ui:Button Content="Load" Command="{Binding LoadProfileCommand}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
